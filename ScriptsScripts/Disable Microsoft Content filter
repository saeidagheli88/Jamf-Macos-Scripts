#!/bin/bash
 
LOG_FILE="/var/log/mdatp_network_filter_disable.log"
 
echo "===== $(date) Starting network filter disable =====" >> "$LOG_FILE"
 
/usr/local/bin/mdatp system-extension network-filter disable >> "$LOG_FILE" 2>&1
 
EXIT_CODE=$?
 
echo "Command exit code: $EXIT_CODE" >> "$LOG_FILE"
 
if [ $EXIT_CODE -eq 0 ]; then
    echo "Network filter disable command executed." >> "$LOG_FILE"
else
    echo "Failed to disable network filter." >> "$LOG_FILE"
fi
 
echo "===== $(date) Finished =====" >> "$LOG_FILE"
exit $EXIT_CODE
